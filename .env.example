# Mesh env keys (documentation only). Real values live in ops/.env, never here.
# No secrets in the mesh/ directory.

# Bearer token the sync clients use to authenticate to the hub (milestone S).
MESH_HUB_TOKEN=your_hub_token_here

# --- Embeddings (BYOAI, milestone V) -----------------------------------------
# Semantic search. Point this at your OWN sovereign endpoint (a local Ollama, a
# self-hosted model server). Note: `mesh embed` POSTs note bodies to this
# endpoint, so a cloud endpoint sends vault content off-box. Keep it local to
# stay sovereign. After setting these, run `mesh embed <vault>`.
MESH_EMBED_ENDPOINT=http://localhost:11434/v1
MESH_EMBED_MODEL=nomic-embed-text
MESH_EMBED_KEY=
# Asymmetric models (nomic-style) need task prefixes; leave empty otherwise.
MESH_EMBED_DOC_PREFIX=search_document:
MESH_EMBED_QUERY_PREFIX=search_query:

# --- Rerank cross-encoder (BYOAI) --------------------------------------------
# Optional top-1 precision booster. Independent of embeddings (works with or
# without vectors). Speaks the Cohere/Jina /rerank wire format. A LOCAL server
# (see tools/rerank-server) keeps note bodies on-box; a cloud reranker POSTs the
# top ~30 candidate note bodies PER QUERY off-box, so prefer local to stay
# sovereign. Unset both to turn rerank off.
MESH_RERANK_ENDPOINT=http://127.0.0.1:8787/rerank
MESH_RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
MESH_RERANK_KEY=
