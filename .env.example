# Mesh env keys (documentation only). Real values live in ops/.env, never here.
# No secrets in the mesh/ directory.

# --- mesh-hub (team sync, milestone S1) --------------------------------------
# The hub has NO startup secret: it mints per-client bearer tokens at runtime
# (one-time invites -> client tokens stored in hub.db) and authenticates every
# request fail-closed. Clients store their own token under <vault>/.mesh
# (0600), never here. Mint invites with:
#   docker exec mesh-hub mesh-hub invite --repo /var/lib/mesh-hub/vault --user <name>
# Only one tunable (non-secret): the tombstone GC horizon in days (default 90).
MESH_HUB_GC_HORIZON=90

# --- Embeddings (BYOAI, milestone V) -----------------------------------------
# Semantic search. Point this at your OWN sovereign endpoint (a local Ollama, a
# self-hosted model server). Note: `mesh embed` POSTs note bodies to this
# endpoint, so a cloud endpoint sends vault content off-box. Keep it local to
# stay sovereign. After setting these, run `mesh embed <vault>`.
MESH_EMBED_ENDPOINT=http://localhost:11434/v1
MESH_EMBED_MODEL=nomic-embed-text
MESH_EMBED_KEY=
# Asymmetric models (nomic-style) need task prefixes; leave empty otherwise.
MESH_EMBED_DOC_PREFIX=search_document:
MESH_EMBED_QUERY_PREFIX=search_query:

# --- Rerank cross-encoder (BYOAI) --------------------------------------------
# Optional top-1 precision booster. Independent of embeddings (works with or
# without vectors). Speaks the Cohere/Jina /rerank wire format. A LOCAL server
# (see tools/rerank-server) keeps note bodies on-box; a cloud reranker POSTs the
# top ~30 candidate note bodies PER QUERY off-box, so prefer local to stay
# sovereign. Unset both to turn rerank off.
MESH_RERANK_ENDPOINT=http://127.0.0.1:8787/rerank
MESH_RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
MESH_RERANK_KEY=
# Blend: head score = a*cross-encoder + (1-a)*fused, a in [0,1]. Default 1.0
# (pure rerank, the proven best on Hive). Lower it only on a keyword-heavy corpus
# where the lexical/graph signal deserves a vote; on Hive lowering it hurt.
MESH_RERANK_BLEND=1.0

# --- Fusion weights (optional, learned via `mesh tune`) ----------------------
# Override the built-in fusion weights (FTS / graph-BM25 / vector cosine). Leave
# unset to use the built-in defaults. Fit them to your own labelled queries with
# `mesh tune <cases.json> --test <held-out.json>` and paste the winner here.
# Note: with rerank on, fusion weights are washed out (the cross-encoder owns the
# head); these matter mainly for the vectors-on, rerank-off configuration.
MESH_WEIGHT_FTS=
MESH_WEIGHT_GRAPH=
MESH_WEIGHT_VEC=
